

<div id="<%= dom_id project %>">
  <div class="d-flex flex-row justify-content-center">

    <div class="card text-center" style="width: 19rem;">
      <div class="card-body">
        <div class="img-responsive center-block">      
          <% if project.image.present? %>  
            <% # debugger %>
            <%= image_tag project.image, width: "200", class: "card-img-top" %>
          <% else %>
            <h2 class="text-center my-5 text-secondary"> No Image </h2>
          <% end %>
        </div>

        <h5 class="card-title"><%= project.name %></h5>
        <h6 class="card-subtitle"><%= organization_name project.organization_id %></h6>
        <p class="card-text mt-2"><%= project.details %></p>
        <p class="card-text mt-2"><%= project.expected_completion_date %></p>
      </div>
    </div>
  </div>

  <div class="d-flex flex-row justify-content-center mt-0">
    <% # debugger %>
    <%= link_to "New Item", new_item_path(project_id: project.id.to_s), class: "btn btn-success btn-sm mt-1 mx-3" %>

    <%= link_to edit_organization_project_path(@org_active, project) do %>
      <%= fa_icon "edit 2x", class: "mt-1 mx-2 text-success" %>
    <% end %>

    <%= link_to new_organization_project_path(@org_active) do %>
      <%= fa_icon "plus-circle 2x", class: "mt-1 mx-2 text-primary" %>
    <% end %>

    <%= link_to organization_projects_path(@org_active) do %>
      <%= fa_icon "list 2x", class: "mt-1 mx-2" %>
    <% end %>

    <%= link_to  [@org_active, project], data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } do %>
      <%= fa_icon "trash 2x", class: "mt-1 mx-2 text-danger" %>
    <% end %>


  </div>

  <div class="mt-3">
    <%= render 'items/list', project: project %>
  </div>
</div>

