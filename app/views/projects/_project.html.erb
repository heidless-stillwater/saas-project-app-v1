

<div id="<%= dom_id project %>">
  <div class="card card-header text-center" style="width: 19rem;">
    <div class="card-body">
      <h5 class="card-title mt-2 fs-2"><%= Organization.find(project.organization_id).name %></h5>
      <h5 class="card-title mt-2 fs-2"><%= project.name %></h5>

      <div class="img-responsive center-block">      
        <% if project.image.present? %>  
          <% # debugger %>
          <%= image_tag project.image, width: "200", class: "mx-auto d-block" %>
        <% else %>
          <h2 class="text-center my-5 text-secondary"> No Image </h2>
        <% end %>
      </div>

      <h5 class="card-title mt-2 fs-2"><%= project.details %></h5>
      <h5 class="card-title mt-2 fs-2"><%= project.expected_completion_date %></h5>
    </div>
  </div>
</div>

